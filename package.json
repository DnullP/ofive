{
  "name": "ofive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "web:dev": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "tauri:web:dev": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "tauri:nostrict": "VITE_DISABLE_STRICT_MODE=true bun run tauri dev",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "proto:generate": "node scripts/build-sidecar.mjs --generate-only",
    "proto:check": "node scripts/build-sidecar.mjs --generate-only && git diff --exit-code -- sidecars/go/ofive-ai-agent/gen/ofive/aiv1",
    "check:guards": "node scripts/check-guards.mjs",
    "check:backend-logs": "node scripts/check-backend-logs.mjs",
    "fix:backend-logs": "node scripts/check-backend-logs.mjs --fix",
    "check:theme-colors": "node scripts/check-theme-colors.mjs",
    "check:i18n-copy": "node scripts/check-i18n-copy.mjs",
    "check:editor-read-parity": "node scripts/check-editor-read-parity.mjs",
    "web:build": "bun run check:guards && tsc && vite build",
    "web:preview": "vite preview --host 127.0.0.1 --port 4174 --strictPort",
    "build": "bun run check:guards && tsc && vite build",
    "test:go": "cd sidecars/go/ofive-ai-agent && go test ./...",
    "test": "bun test",
    "test:ci:unit": "node scripts/run-unit-tests-with-summary.mjs",
    "test:rust": "node scripts/run-rust-tests-with-tauri-config.mjs",
    "test:rust:core": "node scripts/run-rust-tests-with-tauri-config.mjs --profile core",
    "test:rust:sidecar": "node scripts/run-rust-tests-with-tauri-config.mjs --profile sidecar",
    "test:playwright:install": "bunx playwright install --with-deps chromium",
    "test:workflow": "bun run test:go && bun run build:sidecar && bun run test && bun run test:rust && bun run test:e2e --reporter=line && bun run build",
    "test:full": "bun run test:workflow",
    "preview": "vite preview",
    "tauri": "node scripts/run-with-protoc.mjs tauri",
    "test:e2e": "bunx playwright test --config playwright.config.ts",
    "test:e2e:ci": "bunx playwright test --config playwright.config.ts --grep-invert @mouse-drag",
    "test:e2e:mouse-drag": "bunx playwright test --config playwright.config.ts --grep @mouse-drag",
    "test:e2e:ui": "bunx playwright test --config playwright.config.ts --ui",
    "test:e2e:headed": "bunx playwright test --config playwright.config.ts --headed",
    "test:perf:frontend": "bunx playwright test --config playwright.perf.config.ts --reporter=line",
    "test:perf:backend": "mkdir -p test-results/perf && rm -f test-results/perf/backend-query-bench.jsonl && OFIVE_PERF_RESULTS_DIR=$PWD/test-results/perf node scripts/run-with-protoc.mjs cargo bench --manifest-path src-tauri/Cargo.toml --bench query_workload_bench -- --nocapture",
    "test:perf": "bun run test:perf:frontend && bun run test:perf:backend && bun run report:perf",
    "report:perf": "node scripts/perf-report.mjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@cosmos.gl/graph": "^2.6.4",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xyflow/react": "^12.10.1",
    "codemirror": "^6.0.2",
    "dockview": "^4.9.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.13",
    "katex": "^0.16.33",
    "lucide-react": "^0.564.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "web-vitals": "^5.2.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.3.9",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}