{
  "name": "ofive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "web:dev": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "tauri:web:dev": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "check:backend-logs": "node scripts/check-backend-logs.mjs",
    "fix:backend-logs": "node scripts/check-backend-logs.mjs --fix",
    "check:theme-colors": "node scripts/check-theme-colors.mjs",
    "web:build": "bun run check:backend-logs && bun run check:theme-colors && tsc && vite build",
    "web:preview": "vite preview --host 127.0.0.1 --port 4174 --strictPort",
    "build": "bun run check:backend-logs && bun run check:theme-colors && tsc && vite build",
    "test": "bun test",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:playwright:install": "bunx playwright install --with-deps chromium",
    "test:full": "bun test && cargo test --manifest-path src-tauri/Cargo.toml && bunx playwright test",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:headed": "bunx playwright test --headed"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@cosmos.gl/graph": "^2.6.4",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "codemirror": "^6.0.2",
    "dockview": "^4.9.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.13",
    "katex": "^0.16.33",
    "lucide-react": "^0.564.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.3.9",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}